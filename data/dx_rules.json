{
  "_meta": {
    "version": "0.1",
    "note": "診斷規則表。每條規則：any=任一條件符合即觸發、all=全部符合。op: > >= < <= ==。'qual_positive'=檢驗項目為陽性。切點預設使用 lab_dict 的 ref 範圍上下限；若需自訂可直接寫 value。",
    "updated": "2026-05-14"
  },
  "rules": [
    {
      "id": "diabetes_mellitus",
      "name": "Diabetes mellitus",
      "logic": "any",
      "criteria": [
        {
          "item": "HbA1c",
          "op": ">=",
          "value": 6.5
        },
        {
          "item": "GLU-AC",
          "op": ">=",
          "value": 126
        }
      ],
      "icd10": "E11.9",
      "icd10_desc": "Type 2 diabetes mellitus without complications"
    },
    {
      "id": "prediabetes",
      "name": "Prediabetes (IFG/IGT)",
      "logic": "any",
      "exclude_if": [
        "diabetes_mellitus"
      ],
      "criteria": [
        {
          "item": "HbA1c",
          "op": "between",
          "value": [
            5.7,
            6.4
          ]
        },
        {
          "item": "GLU-AC",
          "op": "between",
          "value": [
            100,
            125
          ]
        }
      ],
      "icd10": "R73.03",
      "icd10_desc": "Prediabetes"
    },
    {
      "id": "dyslipidemia",
      "name": "Dyslipidemia",
